{
  "mcpServers": {
    "opentendril": {
      "command": "tendril",
      "args": ["serve", "mcp", "stdio"],
      "env": {
        "OPENTENDRIL_POLLEN": "claude"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
