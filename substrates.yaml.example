# OpenTendril substrate configuration.
#
# Place this file at ./substrates.yaml or ./.tendril/substrates.yaml.
# Each key under `substrates` is a named repository target passed to
# `sproutTendril` (or `tendril sprout run --substrate <name>`).

# Reusable named credential profiles. Reference one from a substrate with
# `profile: <name>` instead of repeating auth/sign inline.
credentials:
  work:
    auth:
      method: pat
      env: GITHUB_TOKEN_WORK        # one token per environment
    sign:
      method: gpg
      key: ABCD1234

substrates:
  # Local substrate: `path` exists, so the Stem operates on the checkout in
  # place. A bare `auth: ENV_VAR` is shorthand for HTTPS PAT auth.
  core:
    path: /home/user/dev/opentendril/core
    url: https://github.com/opentendril/core.git
    branch: main
    auth: GITHUB_TOKEN
    readonly: false

  # Foreign read-only substrate: no local `path`, so the Stem clones `url` with
  # the PAT named by `auth`. `readonly: true` discards edits — nothing is pushed
  # or merged back. Naming its own env var scopes one token to this repo.
  api:
    url: https://github.com/myorg/api.git
    branch: develop
    auth: MYORG_API_TOKEN
    readonly: true

  # SSH auth (no PAT), commit signing, and a persistent OT-managed checkout.
  internal-lib:
    url: git@github.com:myorg/internal-lib.git
    branch: main
    auth:
      method: ssh                    # pat | ssh | none
      key: ~/.ssh/id_ot_internal
    sign:
      method: ssh                    # ssh | gpg
      key: ~/.ssh/id_ot_internal
    checkout:
      mode: managed                  # ephemeral (default) | managed | path

  # Inherit auth + signing from the `work` credential profile above.
  other:
    url: https://github.com/myorg/other.git
    branch: main
    profile: work

# Reference, not secrets:
# - `auth` (and `credentials.*.auth`) names an ENVIRONMENT VARIABLE, never a raw
#   token. GITHUB_TOKEN is the canonical GitHub PAT var; GITHUB_PERSONAL_ACCESS_TOKEN
#   is accepted as a fallback when the referenced one is unset.
# - `auth.method`: `pat` (env-var PAT), `ssh` (key-based, no PAT), or `none` (anonymous).
# - `sign`: optional `ssh` or `gpg` commit signing; `key` is a key path or GPG key id.
# - `checkout.mode`: `ephemeral` (throwaway /tmp clone), `managed` (persistent OT-owned
#   dir under ~/.opentendril/substrates/<name>), or `path` (explicit `checkout.path`).
# - `readonly: true` keeps the terrarium's edits discarded — no host or remote writeback.
# - `path` is optional; if set and present on disk, the local checkout is used in place.
