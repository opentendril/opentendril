# === Tendril Configuration ===

# LLM API Keys (add whichever providers you use)
GROK_API_KEY=xai-your-grok-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key

# Default LLM provider: grok | anthropic | openai | local
DEFAULT_LLM_PROVIDER=grok

# Local inference (optional — requires NVIDIA GPU + vLLM service)
LOCAL_MODEL_NAME=Qwen/Qwen3-8B-AWQ
LOCAL_INFERENCE_URL=http://inference:8000/v1

# Infrastructure
POSTGRES_PASSWORD=ChangeMeSecure123!
REDIS_PASSWORD=ChangeMeRedis456!
SECRET_KEY=generate_with_openssl_rand_-hex_32

# GitHub (for self-building features)
GITHUB_TOKEN=ghp_your_github_pat

# HuggingFace (for embedding model downloads)
HF_TOKEN=hf_your_huggingface_token

# Google (Gemini)
GOOGLE_API_KEY=your_google_gemini_key

# Sandbox (secure code execution)
SANDBOX_TOKEN=generate_with_openssl_rand_-hex_16
SANDBOX_ENABLED=true

# External project mode — point Tendril at your own repo
# When these are set, Tendril operates on your project instead of itself.
# TENDRIL_WORKSPACE_ROOT=/workspace
# TENDRIL_PROJECT_PATH=/path/to/your/project
