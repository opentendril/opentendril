# === OpenTendril Stem Configuration ===
# Copy to .env — the Ollama-first defaults below run a fully local Stem.

# Default LLM provider: local | anthropic | openai | grok | google | openrouter
DEFAULT_LLM_PROVIDER=local

# Local inference via Ollama (OpenAI-compatible endpoint).
# The Stem also falls back across host.docker.internal/localhost/127.0.0.1
# automatically, so this works from the host and from inside containers.
LOCAL_MODEL_NAME=qwen2.5-coder:7b
LOCAL_INFERENCE_URL=http://localhost:11434/v1

# GitHub PAT for terrarium git clones/pushes (fine-grained, repo-scoped).
# Tip: use .envrc (see .envrc.example) to source it from `gh auth token`.
GITHUB_TOKEN=

# Terrarium (isolated code execution in ephemeral Docker containers)
TERRARIUM_ENABLED=true

# SQLite persistence for sessions, chat logs, EventBus telemetry, and Sprout
# execution histories (.tendril/history.db). Set false to bypass SQLite.
OPENTENDRIL_DB_LOGGING=true

# --- Optional ---

# Cloud provider API keys (only needed when DEFAULT_LLM_PROVIDER is not local)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# OPENAI_API_KEY=sk-your-openai-key
# GROK_API_KEY=xai-your-grok-api-key
# GOOGLE_API_KEY=your-google-gemini-key
# OPENROUTER_API_KEY=your-openrouter-key

# Model tier overrides — pin specific model versions without changing code.
# If unset, the Stem auto-discovers the best available model per provider.
# Format: <PROVIDER>_<TIER>_MODEL where tier is FAST | STANDARD | POWER.
# ANTHROPIC_POWER_MODEL=claude-opus-4-7
# OPENROUTER_STANDARD_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_FAST_MODEL=google/gemini-2.0-flash-001

# Coordinator overrides — route orchestration (planning) turns to a different
# provider/model than the workers.
# COORDINATOR_LLM_PROVIDER=local
# COORDINATOR_MODEL_NAME=qwen2.5-coder:14b
# COORDINATOR_LOCAL_INFERENCE_URL=http://localhost:11434/v1

# Persistent state & remote telemetry (OS of OT)
# OPENTENDRIL_DB_PATH=.tendril/history.db
# Remote EventBus sinks — comma-separated redis:// ws:// wss:// http(s):// URLs.
# OPENTENDRIL_REMOTE_SINKS=redis://:pass@localhost:6379/opentendril-events,wss://fleet.example.com/ingest
