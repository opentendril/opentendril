# === Tendril Configuration ===

# LLM API Keys (add whichever providers you use)
GROK_API_KEY=xai-your-grok-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
OPENROUTER_API_KEY=your-openrouter-key

# Default LLM provider: grok | anthropic | openai | google | openrouter | local
DEFAULT_LLM_PROVIDER=grok

# --- Model Tier Overrides (optional) ---
# Pin specific model versions without changing code. If unset, Tendril auto-discovers
# the best available model from the provider's API (cached 24h).
# Format: <PROVIDER>_<TIER>_MODEL=<model-name>
# Examples:
#   ANTHROPIC_POWER_MODEL=claude-opus-4-7
#   OPENROUTER_STANDARD_MODEL=anthropic/claude-3.5-sonnet
#   OPENROUTER_FAST_MODEL=google/gemini-2.0-flash-001

# Complexity Assessor — auto-selects fast/standard/power tier per request
# Disable to skip the assessment step and always use the default tier
ASSESSOR_ENABLED=true

# Local inference (optional — requires NVIDIA GPU + vLLM service)
LOCAL_MODEL_NAME=Qwen/Qwen3-8B-AWQ
LOCAL_INFERENCE_URL=http://inference:8000/v1

# Infrastructure
POSTGRES_PASSWORD=ChangeMeSecure123!
REDIS_PASSWORD=ChangeMeRedis456!
SECRET_KEY=generate_with_openssl_rand_-hex_32

# KV Store provider — redis (default) | upstash | memory
# 'memory' needs no container; 'upstash' is serverless Redis over HTTP
KV_STORE_PROVIDER=redis
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Vector Store provider — pgvector (default) | pinecone | weaviate
VECTOR_STORE_PROVIDER=pgvector
# Pinecone (managed, serverless)
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX_NAME=tendril
# PINECONE_NAMESPACE=
# Weaviate (open-source, self-hostable or cloud)
# WEAVIATE_URL=http://weaviate:8080
# WEAVIATE_API_KEY=
# WEAVIATE_INDEX_NAME=Tendril

# GitHub (for self-building features)
GITHUB_TOKEN=ghp_your_github_pat

# HuggingFace (for embedding model downloads)
HF_TOKEN=hf_your_huggingface_token

# Google (Gemini)
GOOGLE_API_KEY=your_google_gemini_key

# Terrarium (secure code execution)
TERRARIUM_TOKEN=generate_with_openssl_rand_-hex_16
TERRARIUM_ENABLED=true

# External project mode — point Tendril at your own repo
# When these are set, Tendril operates on your project instead of itself.
# TENDRIL_WORKSPACE_ROOT=/workspace
# TENDRIL_PROJECT_PATH=/path/to/your/project
